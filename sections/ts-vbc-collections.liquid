            "fallback_image_url": "https://media.base44.com/images/public/69d4488a5dfc8f6017add6a5/b6e179db2_generated_image.png",
            "cta_label": "Shop Now"
          }
        },
        {
          "type": "tile",
          "settings": {
            "large": false,
            "tag": "Baking Essentials",
            "title": "Cacao Powder",
            "subtitle": "Stone-ground pure cacao powder",
            "fallback_image_url": "https://media.base44.com/images/public/69d4488a5dfc8f6017add6a5/27bf60b05_generated_image.png",
            "cta_label": "Shop Now"
          }
        },
        {
          "type": "tile",
          "settings": {
            "large": false,
            "tag": "Pure & Natural",
            "title": "Cacao Butter",
            "subtitle": "Cold-pressed, food-grade cacao butter",
            "fallback_image_url": "https://media.base44.com/images/public/69d4488a5dfc8f6017add6a5/d16bebc9a_generated_image.png",
            "cta_label": "Shop Now"
          }
